rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isSignedIn() && 
        (request.auth.uid == userId || isAdmin());

      allow update: if isSignedIn() && 
        request.auth.uid == userId && 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'photoUrl', 'phoneNumber', 'updatedAt']);
      
      allow create, delete: if false;

      match /favorites/{eventId} {
        allow read, delete: if isSignedIn() && request.auth.uid == userId;

        allow create: if isSignedIn() && request.auth.uid == userId &&
          request.resource.data.keys().hasOnly(['createdAt']) &&
          request.resource.data.createdAt == request.time;
      }
    }

    match /categories/{categoryId} {
      allow read: if resource.data.status == 'approved' || isAdmin();

      allow write: if false;
    }

    match /events/{eventId} {
      function isEventOwner() {
        return isSignedIn() && 
          request.auth.uid == resource.data.organizerId;
      }

      allow read: if resource.data.status == 'published' ||
        isEventOwner() || isAdmin();
      
      allow write: if false;

      function parentEvent() {
        return get(/databases/$(database)/documents/events/$(eventId)).data;
      }

      function parentReadable() {
        return parentEvent().status == 'published' ||
          (isSignedIn() && request.auth.uid == parentEvent().organizerId) ||
          isAdmin();
      }

      match /content/{docId} {
        allow read: if parentReadable();
        allow write: if false;
      }

      match /ticketTypes/{ttId} {
        allow read: if parentReadable();
        allow write: if false;
      }

      match /seatmap/{docId} {
        allow read: if parentReadable();
        allow write: if false;
      }

      match /search/{docId} {
        allow read, write: if false;
      }
    }
  }
}
